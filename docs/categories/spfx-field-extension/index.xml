    <item>
      <title>Field Customiser sample using Text Analytics API</title>
      <link>http://localhost:1313/sp-dev-fx-webparts/samples/pnp-sp-dev-spfx-extensions-react-field-text-analytics-api/</link>
      <pubDate>Thu, 18 Jan 2018 00:00:00 +0000</pubDate>
